# CAD (Course A Day) env contract — copy to .env.local and fill in.
# Synced to Vercel (matsiems scope) via /abc-vercel sync env cad.

# --- Mongo (FLEET DB, shared) ---
# Per ~/APPS/appai/docs/MONGO-FLEET-SCHEMA.md: CAD writes to FLEET.lists with
# {app:'cad', kind:'course'} — no dedicated CAD collection.
# Indexes already exist on FLEET — created by /abc-mongo fleet init.
MONGODB_URI=
MONGODB_DB=FLEET
CAD_APP_ID=cad
CAD_LISTS_KIND=course

# --- S3 com27 (eu-west-2). S3_REGION must be set explicitly:
# Vercel auto-injects AWS_REGION=us-east-1 which silently breaks eu-west-2 reads.
S3_REGION=eu-west-2
S3_BUCKET=com27
S3_PREFIX=cad

# --- Supabase (auth only — content lives in Mongo) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_ALLOWLIST=mat@matsiems.com

# --- Anthropic (daily course generation) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Runware (FLUX cover + Seedance intro loop) ---
RUNWARE_API_KEY=
RUNWARE_IMAGE_MODEL=runware:100@1
RUNWARE_VIDEO_MODEL=bytedance:2@2

# --- GA4 + email ---
NEXT_PUBLIC_GA_ID=
RESEND_API_KEY=

# --- Cron auth ---
CRON_SECRET=

# --- App URL (prod alias — must NOT stay localhost in Vercel) ---
NEXT_PUBLIC_APP_URL=http://localhost:15011
